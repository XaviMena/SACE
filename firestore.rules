rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function autenticado() {
      return request.auth != null;
    }

    function usuario_actual() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function perfil_activo() {
      return autenticado() &&
        usuario_actual().data.estado == "activo";
    }

    function es_admin() {
      return perfil_activo() &&
        usuario_actual().data.rol == "admin";
    }

    match /usuarios/{uid} {
      allow read: if autenticado() && (request.auth.uid == uid || es_admin());
      allow create, update: if autenticado() && (request.auth.uid == uid || es_admin());
      allow delete: if es_admin();
    }

    match /docentes/{docenteId} {
      allow read: if perfil_activo();
      allow create, update, delete: if es_admin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
